% =============================================================================
% literatur.bib — BibLaTeX-Literaturdatenbank
% =============================================================================
% Füge hier alle Quellen im BibTeX-Format ein.
% Empfohlene Eintragstypen:
%   @article    — Zeitschriftenartikel
%   @book       — Bücher
%   @online     — Webseiten / Online-Quellen
%   @manual     — Datenblätter / technische Handbücher
%   @misc       — Sonstige Quellen
%
% Zitieren im Text: \cite{schluessel} oder \autocite{schluessel}
% =============================================================================

% Beispiel-Einträge (durch eigene Quellen ersetzen):

@online{beispiel_web,
  author  = {<<Nachname>>, <<Vorname>>},
  title   = {<<Titel der Webseite>>},
  year    = {<<Jahr>>},
  url     = {https://<<URL>>},
  urldate = {<<JJJJ-MM-TT>>},
}

@book{beispiel_buch,
  author    = {<<Nachname>>, <<Vorname>>},
  title     = {<<Buchtitel>>},
  edition   = {<<Auflage>>},
  publisher = {<<Verlag>>},
  year      = {<<Jahr>>},
  isbn      = {<<ISBN>>},
}

@manual{beispiel_datenblatt,
  author       = {<<Hersteller>>},
  title        = {<<Produktname>> Datasheet},
  organization = {<<Hersteller GmbH / Inc.>>},
  year         = {<<Jahr>>},
  url          = {https://<<URL>>},
}
